rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /theory/{cardId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /promoCodes/{codeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // Amistades — write permitido al propio usuario O al amigo (para añadir en ambas direcciones)
    match /friendships/{userId}/friends/{friendId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == userId || request.auth.uid == friendId);
    }

    // Notificaciones de amistad
    match /friendNotifications/{userId}/items/{itemId} {
      // Solo el destinatario puede leer y borrar sus notificaciones
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      // Cualquier usuario autenticado puede crear una notificación para otro
      allow create: if request.auth != null;
    }

    // Solicitudes de amistad
    match /friendRequests/{userId}/incoming/{fromId} {
      // El destinatario puede leer/eliminar sus solicitudes
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      // Cualquier usuario autenticado puede enviar solicitudes a otro
      allow create: if request.auth != null && request.auth.uid == fromId;
    }
    match /friendRequests/{userId}/outgoing/{toId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progreso de estudio
    match /studyProgress/{userId}/sessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // Chats 1 a 1
    match /chats/{chatId} {
      // list: cualquier usuario autenticado puede listar (query filtra por participants en cliente)
      // get: solo los participantes pueden leer un doc concreto
      allow list: if request.auth != null;
      allow get: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
