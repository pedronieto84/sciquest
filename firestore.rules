rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow any authenticated user to update (needed for competition XP transfers)
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /quizSessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    match /theory/{cardId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
    }
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /promoCodes/{codeId} {
      allow read: if request.auth != null;
      allow write: if false; // Solo admin via SDK
    }

    // Amistades: cada usuario gestiona su propia subcolección
    match /friendships/{userId}/friends/{friendId} {
      // Cualquier usuario autenticado puede leer amigos ajenos (para buscar amigos mutuos)
      allow read: if request.auth != null;
      // Solo el propio usuario puede agregar/eliminar sus amigos
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chats 1 a 1
    match /chats/{chatId} {
      // Solo participantes pueden leer/actualizar el documento del chat
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      // Crear: el usuario debe ser uno de los participantes
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      // Actualizar (lastMessage, etc.): solo participantes
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      // Mensajes dentro del chat
      match /messages/{messageId} {
        // Solo participantes del chat padre pueden leer/escribir mensajes
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false; // Los mensajes no se editan ni eliminan
      }
    }
  }
}
